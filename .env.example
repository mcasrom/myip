# ==============================================================================
# MyIP - Environment Configuration
# ==============================================================================
# Copy this file: cp .env.example .env
# Replace each "YOUR_..." placeholder with your real key/token.
# NEVER commit .env to version control.
# ==============================================================================

# --- SERVER CONFIGURATION ---
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# ==============================================================================
# AI / LLM APIs (FREE Tiers)
# ==============================================================================

# Google Gemini 2.0 Flash
# Purpose: Translate scan results to human-friendly Spanish analysis
# Free tier: 15 RPM, 1,500 RPD (~1,500 scans/day)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# xAI Grok
# Purpose: Generate executive PDF reports, alternative AI analysis
# Free tier: Limited beta, generous daily quota
# Get key: https://console.x.ai/
XAI_API_KEY=YOUR_XAI_API_KEY
XAI_MODEL=grok-beta

# ==============================================================================
# IP GEOLOCATION APIs (FREE - Primary + Fallbacks)
# ==============================================================================

# ipapi.co (Primary - used by browser directly)
# Free tier: 1,000 requests/day, no API key required
# Docs: https://ipapi.co/api/#introduction

# ipinfo.io (Fallback #1)
# Free tier: 50,000 requests/month
# Get token: https://ipinfo.io/signup
IPINFO_TOKEN=YOUR_IPINFO_TOKEN

# ip-api.com (Fallback #2 - No key required)
# Free tier: 45 requests/minute from non-HTTPS
# Docs: http://ip-api.com/docs

# ==============================================================================
# IP REPUTATION & THREAT INTELLIGENCE (FREE)
# ==============================================================================

# AbuseIPDB
# Purpose: Check if IP has been reported for abuse (brute force, spam, etc.)
# Free tier: 1,000 requests/day, score 0-100
# Get key: https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=YOUR_ABUSEIPDB_API_KEY

# VirusTotal
# Purpose: Comprehensive IP reputation from 80+ security vendors
# Free tier: 500 requests/day, 4 requests/minute
# Get key: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=YOUR_VIRUSTOTAL_API_KEY

# Shodan
# Purpose: Discover open ports, services, banners on any public IP
# Free tier: 100 credits/month (1 credit = 1 query), unlimited search API
# Get key: https://account.shodan.io/register
SHODAN_API_KEY=YOUR_SHODAN_API_KEY

# Censys (Fallback for port discovery)
# Purpose: Internet-wide scanner, alternative to Shodan
# Free tier: 250 queries/month
# Get key: https://search.censys.io/account/api
CENSYS_API_ID=YOUR_CENSYS_API_ID
CENSYS_API_SECRET=YOUR_CENSYS_API_SECRET

# Project Honey Pot (DNSBL)
# Purpose: Detect IPs associated with email harvesters and spammers
# Free tier: Unlimited DNSBL queries (DNS-based)
# Get key: https://www.projecthoneypot.org/create_account.php
PROJECT_HONEYPOT_API_KEY=YOUR_PROJECT_HONEYPOT_API_KEY

# ==============================================================================
# DNSBL / BLACKLIST SERVERS (FREE - DNS-based, no API keys needed)
# ==============================================================================
DNSBL_SERVERS=zen.spamhaus.org,b.barracudacentral.org,dnsbl.httpbl.org,bl.score.senderscore.com

# ==============================================================================
# EMAIL (Resend API — no SMTP, no Gmail exposure)
# ==============================================================================
# Free tier: 3,000 emails/month
# Get API key: https://resend.com/api-keys
# Default sender: onboarding@resend.dev (Resend's test domain)
# For production, verify your own domain in Resend dashboard.

RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM=MyIP <onboarding@resend.dev>

# ==============================================================================
# STRIPE PAYMENTS (Optional)
# ==============================================================================
# Get keys: https://dashboard.stripe.com/apikeys

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ==============================================================================
# NMAP INTEGRATION (Defensive/Informational - Hetzner VPS only)
# ==============================================================================
# Install nmap: sudo apt install nmap
# WARNING: Only scans PUBLIC IPs. Private/internal IPs are BLOCKED.
# WARNING: nmap requires root for SYN scans. Use -sT (TCP connect) as non-root.

# Enable nmap scanning (default: false for Vercel serverless)
NMAP_ENABLED=false
# Full path to nmap binary
NMAP_PATH=/usr/bin/nmap
# Scan profile: "quick" (top 100 ports), "standard" (top 1000)
# NEVER use "full" (65535 ports) in production - too slow
NMAP_SCAN_PROFILE=quick
# Timeout in seconds for nmap scans
NMAP_TIMEOUT=60

# ==============================================================================
# PYTHON SCRIPTS INTEGRATION
# ==============================================================================
# Python 3 must be installed: sudo apt install python3
# Scripts are in ./scripts/ directory

PYTHON_PATH=/usr/bin/python3
SCRIPTS_DIR=./scripts

# ==============================================================================
# SECURITY & RATE LIMITING
# ==============================================================================
GUEST_SCAN_LIMIT=3
FREE_SCAN_COOLDOWN_HOURS=24
GLOBAL_RATE_LIMIT_PER_HOUR=60

# ==============================================================================
# TLS / SSL
# ==============================================================================
# Set to "0" ONLY in development with self-signed certificates.
# NEVER disable in production.
NODE_TLS_REJECT_UNAUTHORIZED=
